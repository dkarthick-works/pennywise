# Postgres credentials — used by both the db container and the app
POSTGRES_USER=ledger
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=ledger

# App — DATABASE_URL is constructed by docker-compose from the vars above
PORT=8080
JWT_SECRET=change-me-minimum-32-char-secret
JWT_USER_CLAIM=sub
JWT_EMAIL_CLAIM=email
GOAUTH_BASE_URL=https://sign.deeka.work
CORS_ORIGINS=https://your-domain.com
