# Full Postgres connection URL — point at any existing DB on the server.
# The app will create the "pennywise" database if it doesn't exist, then
# run all migrations automatically on startup.
DATABASE_URL=postgres://user:password@host:5432/postgres?sslmode=disable

PORT=8080
JWT_SECRET=change-me-minimum-32-char-secret
JWT_USER_CLAIM=sub
JWT_EMAIL_CLAIM=email
GOAUTH_BASE_URL=https://sign.deeka.work
CORS_ORIGINS=https://your-domain.com
