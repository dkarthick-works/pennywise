# Pennywise backend configuration. Copy to .env and adjust.

PORT=8080

DATABASE_URL=postgres://ledger:ledger@localhost:5432/ledger?sslmode=disable

# Shared HS256 secret — MUST match the secret Goauth signs its JWTs with.
JWT_SECRET=change-me

# Goauth tokens use "sub" for the user UUID.
JWT_USER_CLAIM=sub
JWT_EMAIL_CLAIM=email

# Base URL of the Goauth service we proxy /api/auth/* to.
GOAUTH_BASE_URL=http://localhost:8090

# Comma-separated allowed CORS origins for the SPA.
CORS_ORIGINS=http://localhost:5173
